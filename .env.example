# Root environment variables (copy to .env and adjust values)

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=beautyfunnels
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/beautyfunnels?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_JWT_SECRET=change-me
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100

# Stripe (mock in dev)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google OAuth (calendar sync)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/integrations/google/callback

# NextAuth (web panel)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

# Expo (mobile)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Storage (S3-compatible)
S3_ENDPOINT=https://example.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret
S3_BUCKET=beautyfunnels-dev

